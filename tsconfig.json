{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/scripts/user-onboard.js",
    "src/**/*.ts",
    "src/scripts/createOrganization.js",
    "src/scripts/organization-onboard.js"
  ],
  "exclude": ["node_modules"]
}
